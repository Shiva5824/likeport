# Spotify Developer Dashboard credentials
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# NextAuth.js v5 secret. Generate with: `openssl rand -base64 32`
# (NextAuth v5 reads AUTH_SECRET; NEXTAUTH_SECRET is also accepted as a fallback.)
AUTH_SECRET=
NEXTAUTH_SECRET=

# The canonical URL of your deployment.
# NextAuth v5 uses AUTH_URL (NEXTAUTH_URL is the v4 name and still works).
#
# IMPORTANT: As of Nov 27, 2025 Spotify no longer accepts `localhost` in
# redirect URIs. Use `127.0.0.1` for local development and open the app at
# http://127.0.0.1:3000 (not http://localhost:3000) so cookies match.
# In Vercel: set to your deployment URL (e.g. https://liked-to-playlist.vercel.app)
AUTH_URL=http://127.0.0.1:3000
NEXTAUTH_URL=http://127.0.0.1:3000
